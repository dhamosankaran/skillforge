# --- App ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5199,https://yourdomain.vercel.app
MAX_UPLOAD_SIZE_MB=5

# --- Database ---
# PostgreSQL 16 + pgvector required. Install via Homebrew:
#   brew install postgresql@16 pgvector
DATABASE_URL=postgresql+asyncpg://hireport:dev_password@localhost:5432/hireport

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
FRONTEND_URL=http://localhost:5199

# --- LLM ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
